rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ────────────────────────────────────────────────────────────────
    function isAdmin() {
      return request.auth != null && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        request.auth.uid == "33EFXNGFH1XXK5nHyDh6AzG4kDL2"
      );
    }

    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // Protects subscription/plan fields from direct client writes
    // Only server-side (Cloud Functions) can write these
    function noSubscriptionFieldsChanged() {
      return !request.resource.data.diff(resource.data).affectedKeys()
        .hasAny(['plan', 'status', 'expiresAt']);
    }

    // ── Users ──────────────────────────────────────────────────────────────────
    match /users/{userId} {
      // Users can read their own doc; admins can read all
      allow read: if isOwner(userId) || isAdmin();

      // Users can write their own doc ONLY IF they don't touch subscription fields
      // Subscription fields (plan, status, expiresAt) are server-only
      allow create: if isOwner(userId);
      allow update: if (isOwner(userId) && noSubscriptionFieldsChanged()) || isAdmin();
      allow delete: if isAdmin();

      match /trades/{tradeId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
      match /transactions/{transactionId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
      match /settings/{settingId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }

    // ── Payments — READ only by owner; WRITES are server-only ─────────────────
    match /payments/{paymentId} {
      // Users can only read their own payments (for status checks)
      allow read: if request.auth != null && resource.data.uid == request.auth.uid;
      // NO client writes — only Cloud Functions can create/update
      allow write: if false;
      // Admins can see all payments
      allow read, write: if isAdmin();
    }

    // ── Notifications — Users read their own; server writes ───────────────────
    match /notifications/{notifId} {
      allow read: if request.auth != null && resource.data.uid == request.auth.uid;
      // Allow users to mark as read
      allow update: if request.auth != null &&
                       resource.data.uid == request.auth.uid &&
                       request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
      allow create, delete: if false; // Server-only
      allow read, write: if isAdmin();
    }

    // ── Support Tickets ────────────────────────────────────────────────────────
    match /tickets/{ticketId} {
      allow create: if request.auth != null;
      allow read: if request.auth != null && (resource.data.uid == request.auth.uid || isAdmin());
      allow update, delete: if isAdmin();
    }

    // ── Admin List ─────────────────────────────────────────────────────────────
    match /admins/{adminId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // ── Collection Group: All Trades (Admin reporting) ─────────────────────────
    match /{path=**}/trades/{tradeId} {
      allow read: if isAdmin();
    }
  }
}
