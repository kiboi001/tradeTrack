rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Check if user is an administrator
    function isAdmin() {
      // Safety net: Hardcoded owner UID if collection check fails
      return request.auth != null && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        request.auth.uid == "33EFXNGFH1XXK5nHyDh6AzG4kDL2"
      );
    }

    // User Data Rules
    match /users/{userId} {
      allow read, write: if request.auth != null && (request.auth.uid == userId || isAdmin());
      
      match /trades/{tradeId} {
        allow read, write: if request.auth != null && (request.auth.uid == userId || isAdmin());
      }
      match /transactions/{transactionId} {
        allow read, write: if request.auth != null && (request.auth.uid == userId || isAdmin());
      }
      match /settings/{settingId} {
        allow read, write: if request.auth != null && (request.auth.uid == userId || isAdmin());
      }
    }

    // Support Ticket Rules
    match /tickets/{ticketId} {
      allow create: if request.auth != null;
      allow read: if request.auth != null && (resource.data.uid == request.auth.uid || isAdmin());
      allow update, delete: if request.auth != null && isAdmin();
    }

    // Admin List
    match /admins/{adminId} {
       allow read: if request.auth != null;
       allow write: if isAdmin(); // Only admins can add other admins
    }

    // Collection Group for Global Stats
    match /{path=**}/trades/{tradeId} {
      allow read: if request.auth != null && isAdmin();
    }
  }
}
